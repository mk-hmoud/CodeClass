DB_USER=user
DB_HOST=db
DB_NAME=codeclass
DB_PASSWORD=changeme
DB_PORT=5432

REDIS_HOST=redis
REDIS_PORT=6379

NODE_ENV=production
PORT=5000

JWT_SECRET=change_this_to_a_long_random_secret

# URL the server allows CORS requests from (the frontend origin)
FRONTEND_URL=http://localhost

# Vite client: URL the browser uses to reach the API
# In production with the nginx proxy this should be empty (requests go through /api)
VITE_API_URL=/api